# Database (Neon / Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Server
PORT=3001
# 本番でURLを固定したい場合のみ設定 (省略時はリクエストのHostから自動推測)
# PUBLIC_BASE_URL="https://api.example.com"

# CORS で許可するフロントエンドのオリジン (カンマ区切り。"*" で全許可)
# ALLOWED_ORIGINS="https://app.example.com,https://www.example.com"

# Cloudinary (画像アップロード先)
# https://cloudinary.com/console から取得し、絶対にコミットしないこと。
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# アップロード時のフォルダ名 (任意, デフォルト: tokyo-land)
# CLOUDINARY_UPLOAD_FOLDER="tokyo-land"
